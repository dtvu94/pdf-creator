        [2, 0,  5], [2, 1, 11], [2, 2, 10], [2, 3, 15], [2, 4, 12], [2, 5,  5], [2, 6,  2],
        [3, 0,  3], [3, 1, 10], [3, 2,  8], [3, 3, 13], [3, 4,  9], [3, 5,  4], [3, 6,  1],
        [4, 0,  4], [4, 1,  9], [4, 2,  7], [4, 3, 10], [4, 4,  8], [4, 5,  6], [4, 6,  3],
        [5, 0,  2], [5, 1,  5], [5, 2,  4], [5, 3,  6], [5, 4,  5], [5, 5,  3], [5, 6,  2],
